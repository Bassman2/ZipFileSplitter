    <readme>docs\README.md</readme>
    <dependencies>
      <group targetFramework=".NET10.0" />
      <group targetFramework=".NET9.0" />
    </dependencies>
  </metadata>
  <files>
    <file src="..\Src\ZipFileSplitter10\bin\Release\net10.0\**" target="lib/net10.0" />
    <file src="..\Src\ZipFileSplitter09\bin\Release\net9.0\**" target="lib/net9.0" />
    <file src="..\README.md" target="docs\" />
    <file src="..\LICENSE" target="content" />
  </files>
</package>