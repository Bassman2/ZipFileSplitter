<?xml version="1.0"?>
<package >
  <metadata>
    <id>ZipFileSplitter</id>
    <version>1.0.0</version>
    <title>ZipFileSplitter</title>
    <authors>Ralf Beckers</authors>
    <owners>Ralf Beckers</owners>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <projectUrl>https://github.com/Bassman2/ZipFileSplitter</projectUrl>
    <description>ZipFileSplitter</description>
    <releaseNotes>Creation</releaseNotes>
    <copyright>Copyright 2026 (c) by Ralf Beckers</copyright>
    <repository type="git" url="https://github.com/Bassman2/ZipFileSplitter"/>
